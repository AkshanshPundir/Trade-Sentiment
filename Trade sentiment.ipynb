)
merged['classification'].value_counts()
# clean column names
trades.columns = trades.columns.str.strip().str.lower().str.replace(' ', '_')
sentiment.columns = sentiment.columns.str.strip().str.lower()
daily_pnl = merged.groupby(['account','date'])['closed_pnl'].sum().reset_index()

daily_pnl.head()
merged['win'] = merged['closed_pnl'] > 0

win_rate = merged.groupby('account')['win'].mean()

win_rate.head()
avg_trade_size = merged.groupby('account')['size_usd'].mean()

avg_trade_size.head()
trades_per_day = merged.groupby('date').size().reset_index(name='trade_count')

trades_per_day.head()
long_short = merged['side'].value_counts(normalize=True)

print(long_short)
performance = merged.groupby('classification')['closed_pnl'].agg(
    ['mean','median','sum','count']
)

performance
merged['classification'].value_counts(dropna=False)
plot_data = merged.dropna(subset=['classification'])
merged['classification'].value_counts(dropna=False)
trades.columns = trades.columns.str.strip().str.lower().str.replace(' ', '_')
trades.columns = trades.columns.str.strip().str.lower().str.replace(' ', '_')
sentiment.columns = sentiment.columns.str.strip().str.lower().str.replace(' ', '_')
print(trades.columns)
plot_data = merged[['classification','closed_pnl']].dropna()
print(plot_data.shape)
plot_data.head()
plt.figure(figsize=(8,5))

sns.boxplot(
    x='classification',
    y='closed_pnl',
    data=plot_data
)

plt.title("PnL Distribution: Fear vs Greed")
plt.show()
trade_freq = merged.groupby('classification').size().reset_index(name='trade_count')

sns.barplot(
    x='classification',
    y='trade_count',
    data=trade_freq
)

plt.title("Trade Frequency by Sentiment")
plt.show()
plt.figure(figsize=(8,5))

sns.histplot(
    merged['size_usd'],
    bins=50
)

plt.title("Trade Size Distribution")
plt.show()
trades["date"] = pd.to_datetime(
    trades["timestamp_ist"],
    dayfirst=True,
    errors="coerce"
).dt.floor("D")

sentiment["date"] = pd.to_datetime(
    sentiment["date"],
    errors="coerce"
).dt.floor("D")
merged = trades.merge(
    sentiment[["date","classification"]],
    on="date",
    how="left"
)

print("Merged rows:", len(merged))
print(merged["classification"].value_counts(dropna=False))
merged = merged.dropna(subset=["classification"])
print("Rows after cleaning:", len(merged))
bias = pd.crosstab(
    merged["classification"],
    merged["side"],
    normalize="index"
)

bias.plot(kind="bar", stacked=True)

plt.title("Long vs Short Bias by Sentiment")
plt.show()
median_size = merged['size_usd'].median()

merged['size_segment'] = np.where(
    merged['size_usd'] > median_size,
    'High Size',
    'Low Size'
)

merged.groupby(['size_segment','classification'])['closed_pnl'].mean()
trader_freq = merged.groupby('account').size()

threshold = trader_freq.median()

merged['freq_segment'] = merged['account'].map(
    lambda x: 'High Frequency' if trader_freq[x] > threshold else 'Low Frequency'
)

merged.groupby(['freq_segment','classification'])['closed_pnl'].mean()
trader_pnl = merged.groupby('account')['closed_pnl'].sum()

merged['winner_segment'] = merged['account'].map(
    lambda x: 'Winner' if trader_pnl[x] > 0 else 'Loser'
)

merged.groupby(['winner_segment','classification'])['closed_pnl'].mean()
performance.to_csv("performance_by_sentiment.csv")
bias.to_csv("long_short_bias.csv")
daily_pnl.to_csv("daily_trader_pnl.csv")
