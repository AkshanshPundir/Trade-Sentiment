#Duplicate
print("Sentiment Duplicates:", sentiment.duplicated().sum())
print("Trades Duplicates:", trades.duplicated().sum())
print(trades.columns)
# clean column names
trades.columns = trades.columns.str.strip().str.lower().str.replace(' ', '_')

# convert timestamp
